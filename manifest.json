{
  "manifest_version": 3,
  "name": "CleanTwitch",
  "version": "1.0",
  "description": "Keeps Twitch focused on channels you follow. No recommended strangers, no algorithm.",
  "host_permissions": [
    "https://www.twitch.tv/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.twitch.tv/*",
        "https://twitch.tv/*"
      ],
      "js": [
        "redirect.js"
      ],
      "run_at": "document_start"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}